{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "malaysia-sjkc-learning",
  "compatibility_date": "2025-09-02",
  // Static SPA — deployed to Cloudflare Pages. `pages_build_output_dir` points
  // at the prerendered client build; `wrangler pages deploy` uploads it.
  // SPA routing fallback is handled by public/_redirects (/* -> /index.html).
  "pages_build_output_dir": "dist/client"
}
